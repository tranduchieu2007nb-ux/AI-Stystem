<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/css/profile.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</head>
<body>
    <!-- Navbar -->
    <nav>
        <div class="logo">
            CosmoVision
        </div>
        <ul>
            <li><a href="/">Home</a></li>
            <li><a href="/planets">Planets</a></li>
            <li><a href="/constellations">Constellations</a></li>
            <li><a href="/events">Events</a></li>
            <li><a href="/observatories">Observatories</a></li>
            <li><a href="/news">News</a></li>
            <li><a href="/chatbot">AI Chatbot</a></li>
        </ul>
        <div class="right">
            <% if(user){ %>
                <div class="dropdown">
                    <button class="btn btn-outline-info dropdown-toggle rounded-pill" type="button"
                        data-bs-toggle="dropdown" aria-expanded="false">
                        <%= user.fullname %>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li>
                            <a class="dropdown-item" href="/profile">
                                Profile
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item" href="/v1/auth/logout">
                                Log out
                            </a>
                        </li>
                    </ul>
                </div>
                <% } else { %>
                    <a href="/v1/auth/login">Login</a>
                    <a href="/v1/auth/register" class="register-btn"> Register</a>
                    <% } %>
        </div>
    </nav>
<!-- section -->
    <section class="profile">
    
        <div class="profile-left">
    
            <h1>
                Your observing
                <br>
                profile.
            </h1>
    
            <p>
                Keep your identity and location current
                for more relevant recommendations.
            </p>
    
        </div>
    
        <div class="profile-right">
    <% if(error){ %>
    
        <div class="alert alert-danger">
    
            <%= error %>
    
        </div>
    
        <% } %>
    
            <% if(success){ %>
    
                <div class="alert alert-success">
    
                    <%= success %>
    
                </div>
    
                <% } %>
            <form action="/profile/update" method="POST">
                <h2>Profile details</h2>
                <div class="form-group">
                    <label>Full name</label>
                    <input type="text" name="fullname" value="<%= user.fullname %>">
                </div>
                <div class="form-group">
                    <label>Email</label>
                    <input type="email" name="email" value="<%= user.email %>">
                </div>
                <div class="form-group">
                    <label>Location</label>
                    <input type="text" name="location" value="<%= user.location %>">
                </div>
                <button>
                    Save changes
                </button>
            </form>
        </div>
    </section>
</body>
</html>