<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= planet.name %> - CosmoVision</title>
    <link rel="stylesheet" href="/css/home.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <nav>
        <div class="logo">CosmoVision</div>
        <ul>
            <li><a href="/">Home</a></li>
            <li><a href="/planets">Planets</a></li>
            <li><a href="/constellations">Constellations</a></li>
            <li><a href="/events">Events</a></li>
            <li><a href="/observatories">Observatories</a></li>
            <li><a href="/news">News</a></li>
            <li><a href="/profile">Profile</a></li>
        </ul>
        <div class="right">
            <% if(user){ %>
                <div class="dropdown">
                    <button class="btn btn-outline-info dropdown-toggle rounded-pill" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                        <%= user.fullname %>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><a class="dropdown-item" href="/profile">Profile</a></li>
                        <li><a class="dropdown-item" href="#logoutModal" data-bs-toggle="modal">Log out</a></li>
                    </ul>
                </div>
            <% } else { %>
                <a href="/v1/auth/login">Login</a>
                <a href="/v1/auth/register" class="register-btn">Register</a>
            <% } %>
        </div>
    </nav>

    <div class="container" style="padding: 120px 20px; color: #fff;">
        <div class="row">
            <div class="col-md-6">
                <img src="<%= planet.image %>" class="img-fluid rounded" alt="<%= planet.name %>">
            </div>
            <div class="col-md-6">
                <h1><%= planet.name %></h1>
                <p><%= planet.description %></p>
                <ul class="list-group list-group-flush mb-4">
                    <li class="list-group-item bg-transparent text-white">Diameter: <strong><%= planet.diameter %> km</strong></li>
                    <li class="list-group-item bg-transparent text-white">Mass: <strong><%= planet.mass %> x10^24 kg</strong></li>
                    <li class="list-group-item bg-transparent text-white">Gravity: <strong><%= planet.gravity %> m/s²</strong></li>
                    <li class="list-group-item bg-transparent text-white">Atmosphere: <strong><%= planet.atmosphere %></strong></li>
                    <li class="list-group-item bg-transparent text-white">Temperature: <strong><%= planet.temperature %> °C</strong></li>
                    <li class="list-group-item bg-transparent text-white">Distance from Sun: <strong><%= planet.distanceSun %> km</strong></li>
                    <li class="list-group-item bg-transparent text-white">Distance from Earth: <strong><%= planet.distanceEarth %> km</strong></li>
                </ul>
                <% if(planet.facts && planet.facts.length){ %>
                    <h4>Facts</h4>
                    <ul class="list-group list-group-flush">
                        <% planet.facts.forEach(function(fact){ %>
                            <li class="list-group-item bg-transparent text-white">- <%= fact %></li>
                        <% }) %>
                    </ul>
                <% } %>
            </div>
        </div>
    </div>

    <div class="modal fade" id="logoutModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Đăng xuất</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    Bạn có muốn đăng xuất không?
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Không</button>
                    <a href="/v1/auth/logout" class="btn btn-danger">Có</a>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
