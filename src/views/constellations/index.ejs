<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Constellations - CosmoVision</title>
    <link rel="stylesheet" href="/css/home.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <nav>
        <div class="logo">CosmoVision</div>
        <ul>
            <li><a href="/">Home</a></li>
            <li><a href="/planets">Planets</a></li>
            <li><a href="/constellations">Constellations</a></li>
            <li><a href="/events">Events</a></li>
            <li><a href="/observatories">Observatories</a></li>
            <li><a href="/news">News</a></li>
            <li><a href="/profile">Profile</a></li>
        </ul>
        <div class="right">
            <% if(user){ %>
                <div class="dropdown">
                    <button class="btn btn-outline-info dropdown-toggle rounded-pill" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                        <%= user.fullname %>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><a class="dropdown-item" href="/profile">Profile</a></li>
                        <li><a class="dropdown-item" href="#logoutModal" data-bs-toggle="modal">Log out</a></li>
                    </ul>
                </div>
            <% } else { %>
                <a href="/v1/auth/login">Login</a>
                <a href="/v1/auth/register" class="register-btn">Register</a>
            <% } %>
        </div>
    </nav>

    <div class="container" style="padding: 120px 20px;">
        <h1 style="color: #fff; margin-bottom: 24px;">Constellations</h1>
        <div class="row">
            <% if(constellations && constellations.length){ %>
                <% constellations.forEach(function(constellation){ %>
                    <div class="col-md-4 mb-4">
                        <div class="card bg-dark text-white border-0" style="box-shadow: 0 16px 40px rgba(0,0,0,0.25);">
                            <img src="<%= constellation.image %>" class="card-img-top" alt="<%= constellation.name %>" style="height: 220px; object-fit: cover;">
                            <div class="card-body">
                                <h5 class="card-title"><%= constellation.name %></h5>
                                <p class="card-text"><%= constellation.description.substring(0, 120) %>...</p>
                                <a href="/constellations/<%= constellation.slug %>" class="btn btn-outline-info">Xem chi tiết</a>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <p style="color: #fff;">Không có chòm sao nào.</p>
            <% } %>
        </div>
    </div>

    <div class="modal fade" id="logoutModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Đăng xuất</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    Bạn có muốn đăng xuất không?
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Không</button>
                    <a href="/v1/auth/logout" class="btn btn-danger">Có</a>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
