<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Events - CosmoVision</title>
    <link rel="stylesheet" href="/css/home.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>
    <!-- Navbar -->
    <nav>
        <div class="logo">
            CosmoVision
        </div>
        <ul>
            <li><a href="/">Home</a></li>
            <li><a href="/planets">Planets</a></li>
            <li><a href="/constellations">Constellations</a></li>
            <li><a href="/events">Events</a></li>
            <li><a href="/observatories">Observatories</a></li>
            <li><a href="/news">News</a></li>
        </ul>
        <div class="right">
            <% if(user){ %>
                <div class="dropdown">
                    <button class="btn btn-outline-info dropdown-toggle rounded-pill" type="button"
                        data-bs-toggle="dropdown" aria-expanded="false">
                        <%= user.fullname %>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li>
                            <a class="dropdown-item" href="/profile">
                                Profile
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item" href="#logoutModal" data-bs-toggle="modal">
                                Log out
                            </a>
                        </li>
                    </ul>
                </div>
                <% } else { %>
                    <a href="/v1/auth/login">Login</a>
                    <a href="/v1/auth/register" class="register-btn"> Register</a>
                    <% } %>

        </div>
    </nav>
    <div class="container" style="padding:100px 20px;">
        <h1 style="color:#fff;margin-bottom:24px;">Sự kiện</h1>
        <div class="row">
            <% if(events && events.length){ %>
                <% events.forEach(function(event){ %>
                    <div class="col-md-4" style="margin-bottom:20px;">
                        <div class="card" style="background:#0f1a26;border:1px solid rgba(255,255,255,0.04);">
                            <% if(event.image){ %>
                                <img src="<%= event.image %>" class="card-img-top" alt="<%= event.name %>"
                                    style="height:180px;object-fit:cover;border-top-left-radius:10px;border-top-right-radius:10px;">
                                <% } %>
                                    <div class="card-body" style="color:#fff;">
                                        <h5 class="card-title">
                                            <%= event.name %>
                                        </h5>
                                        <p class="card-text" style="color:rgba(255,255,255,0.8);">
                                            <%= event.description.length> 150 ? event.description.substring(0,150) +
                                                '...' : event.description %>
                                        </p>
                                        <p style="font-size:0.9rem;color:rgba(255,255,255,0.7);">Từ: <%= new
                                                Date(event.startDate).toLocaleDateString() %> - Đến: <%= new
                                                    Date(event.endDate).toLocaleDateString() %>
                                        </p>
                                        <a href="/events/<%= event.slug %>" class="btn btn-outline-info">Xem chi
                                            tiết</a>
                                    </div>
                        </div>
                    </div>
                    <% }) %>
                        <% } else { %>
                            <p style="color:#fff;">Chưa có sự kiện nào.</p>
                            <% } %>
        </div>
    </div>
</body>

</html>