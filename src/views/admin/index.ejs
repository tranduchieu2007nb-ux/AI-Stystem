<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Overview - CosmoVision</title>
    <link rel="stylesheet" href="/css/admin.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</head>
<body>
    <nav class="admin-navbar">
        <div class="admin-logo">CosmoVision Admin</div>
        <div class="admin-top-links">
            <a href="/">Trang chủ</a>
            <a href="/profile">Profile</a>
            <a href="#logoutModal" data-bs-toggle="modal">Đăng xuất</a>
        </div>
    </nav>

    <div class="admin-layout">
        <aside class="admin-sidebar">
            <div class="sidebar-title">Operations</div>
            <ul>
                <li><a href="/admin" class="active">Admin Overview</a></li>
                <li><a href="/admin/users">Users</a></li>
                <li><a href="/admin/planets">Planets</a></li>
            </ul>
        </aside>

        <main class="admin-main">
            <section class="admin-hero">
                <div>
                    <p class="small-title">ADMIN DASHBOARD</p>
                    <h1>Welcome back, <%= user.fullname %></h1>
                    <p>Quản lý người dùng, hành tinh và nội dung nhanh chóng từ đây.</p>
                </div>
            </section>

            <section class="admin-cards">
                <div class="stat-card">
                    <p class="stat-name">Users</p>
                    <h2><%= stats.users %></h2>
                    <p>Người dùng đăng ký</p>
                </div>
                <div class="stat-card">
                    <p class="stat-name">Planets</p>
                    <h2><%= stats.planets %></h2>
                    <p>Hành tinh đã lưu</p>
                </div>
                <div class="stat-card">
                    <p class="stat-name">Events</p>
                    <h2><%= stats.events %></h2>
                    <p>Sự kiện đang có</p>
                </div>
                <div class="stat-card">
                    <p class="stat-name">News</p>
                    <h2><%= stats.news %></h2>
                    <p>Tin tức</p>
                </div>
            </section>
        </main>
    </div>

    <div class="modal fade" id="logoutModal" tabindex="-1" aria-labelledby="logoutModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="logoutModalLabel">Đăng xuất</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p>Bạn có muốn đăng xuất không?</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Không</button>
                    <a class="btn btn-danger" href="/v1/auth/logout">Có</a>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
