<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Users - CosmoVision</title>
    <link rel="stylesheet" href="/css/admin.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</head>
<body>
    <nav class="admin-navbar">
        <div class="admin-logo">CosmoVision Admin</div>
        <div class="admin-top-links">
            <a href="/">Trang chủ</a>
            <a href="/profile">Profile</a>
            <a href="#logoutModal" data-bs-toggle="modal">Đăng xuất</a>
        </div>
    </nav>

    <div class="admin-layout">
        <aside class="admin-sidebar">
            <div class="sidebar-title">Operations</div>
            <ul>
                <li><a href="/admin">Admin Overview</a></li>
                <li><a href="/admin/users" class="active">Users</a></li>
                <li><a href="/admin/planets">Planets</a></li>
            </ul>
        </aside>

        <main class="admin-main">
            <div class="admin-section-title">
                <h1>Quản lý người dùng</h1>
                <p>Danh sách tài khoản đang hoạt động.</p>
            </div>

            <div class="admin-table-wrap">
                <table class="table table-dark table-striped align-middle admin-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Họ tên</th>
                            <th>Email</th>
                            <th>Role</th>
                            <th>Created At</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% users.forEach((userData, index) => { %>
                            <tr>
                                <td><%= index + 1 %></td>
                                <td><%= userData.fullname %></td>
                                <td><%= userData.email %></td>
                                <td><%= userData.role %></td>
                                <td><%= new Date(userData.createdAt).toLocaleDateString() %></td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </main>
    </div>

    <div class="modal fade" id="logoutModal" tabindex="-1" aria-labelledby="logoutModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="logoutModalLabel">Đăng xuất</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p>Bạn có muốn đăng xuất không?</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Không</button>
                    <a class="btn btn-danger" href="/v1/auth/logout">Có</a>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
