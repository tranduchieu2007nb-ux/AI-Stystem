<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>
    <div class="container py-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h1>Admin Dashboard</h1>
                <p>Welcome, <%= user.fullname %>
                </p>
            </div>
            <div>
                <a href="/" class="btn btn-secondary">Home</a>
                <a href="/admin/planets/create" class="btn btn-primary">Create Planet</a>
            </div>
        </div>
        <% if (error) { %>
            <div class="alert alert-danger">
                <%= error %>
            </div>
            <% } %>
                <% if (success) { %>
                    <div class="alert alert-success">
                        <%= success %>
                    </div>
                    <% } %>
                        <table class="table table-bordered table-hover">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Slug</th>
                                    <th>Diameter</th>
                                    <th>Mass</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% planets.forEach((planet)=> { %>
                                    <tr>
                                        <td>
                                            <%= planet.name %>
                                        </td>
                                        <td>
                                            <%= planet.slug %>
                                        </td>
                                        <td>
                                            <%= planet.diameter %>
                                        </td>
                                        <td>
                                            <%= planet.mass %>
                                        </td>
                                        <td>
                                            <a href="/admin/planets/<%= planet._id %>/edit"
                                                class="btn btn-sm btn-warning">Edit</a>
                                            <form action="/admin/planets/<%= planet._id %>/delete" method="POST"
                                                class="d-inline">
                                                <button type="submit" class="btn btn-sm btn-danger"
                                                    onclick="return confirm('Delete this planet?')">Delete</button>
                                            </form>
                                        </td>
                                    </tr>
                                    <% }) %>
                            </tbody>
                        </table>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>